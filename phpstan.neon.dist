parameters:
    level: 8
    paths:
        - src
    excludePaths:
        - tests/Fixtures/*
    # The rules compare reflected class-strings against Illuminate FQCNs that are
    # not installed here (only test stubs exist), so PHPStan treats those literal
    # comparisons as always-false. Don't trust PHPDoc class-string types as certain.
    treatPhpDocTypesAsCertain: false

includes:
    - extension.neon
